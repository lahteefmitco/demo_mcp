{
  "name": "personal-expense-manager-mcp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Personal expense manager with PostgreSQL, Express.js API, and a sample MCP server.",
  "scripts": {
    "dev": "node --watch src/app.js",
    "start": "node src/app.js",
    "mcp": "node src/mcp/server.js",
    "db:init": "node src/scripts/init-db.js",
    "db:migrate-auth": "node src/scripts/migrate-auth-schema.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "dotenv": "latest",
    "express": "latest",
    "pg": "latest",
    "sequelize": "latest"
  }
}
