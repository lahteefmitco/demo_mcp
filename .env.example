PORT=3000
# Winston: error, warn, info, http, verbose, debug, silly (default http = request lines + above)
LOG_LEVEL=http
# Relative to repo root unless absolute
LOG_FILE=logs/app.log
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/expense_manager
AUTH_SECRET=replace_with_a_long_random_secret
APP_BASE_URL=http://localhost:3000
MAIL_FROM=no-reply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
LEGACY_USER_NAME=Legacy User
LEGACY_USER_EMAIL=legacy@example.com
LEGACY_USER_PASSWORD=change-me-123456
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_MODEL=mistral-small-latest
MISTRAL_EMBEDDING_MODEL=mistral-embed
MISTRAL_EMBEDDING_DIM=1024
RAG_TOP_K=6
RAG_CHUNK_CHARS=1600
RAG_EMBED_BATCH=16
# Set to yes to allow npm run rag:reindex (truncates ai_documents for all users)
RAG_REINDEX_CONFIRM=no
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=Personal Finance Mobile

# Sarvam (OpenAI-compatible chat completions)
SARVAM_API_KEY=your_sarvam_api_key
SARVAM_MODEL=sarvam-105b

# CORS for browser-based clients (Flutter web)
# Comma-separated list of allowed origins. Example:
# CORS_ORIGINS=http://localhost:5173,https://app.yourdomain.com
CORS_ORIGINS=http://localhost:3000
# Dev-only override: reflect any Origin header when true
CORS_ALLOW_ALL=true
