<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
  </head>
  <body style="margin:0;padding:24px;background:#f4f7fb;font-family:Arial,sans-serif;color:#111827;">
    <div style="max-width:520px;margin:0 auto;background:#ffffff;border-radius:18px;padding:32px;">
      <h1 style="margin-top:0;color:<%= success ? '#0f766e' : '#b91c1c' %>;"><%= title %></h1>
      <p><%= message %></p>
    </div>
  </body>
</html>
